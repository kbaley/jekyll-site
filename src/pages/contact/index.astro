---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Contact Kyle Baley for remote contract engineering, architecture, and fractional technical leadership work."
>
  <section class="page-header">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Let’s talk about the system you need to move forward.</h1>
      <p class="lead">
        The simplest path is email. LinkedIn and GitHub are here too if you want more context first.
      </p>
    </div>
  </section>
  <section class="container contact-panel" aria-label="Contact links">
    <div class="card contact-row">
      <strong>Email</strong>
      <a href="mailto:kyle@baley.org">kyle@baley.org</a>
    </div>
    <div class="card contact-row">
      <strong>LinkedIn</strong>
      <a href="https://www.linkedin.com/in/kylebaley/">linkedin.com/in/kylebaley</a>
    </div>
    <div class="card contact-row">
      <strong>GitHub</strong>
      <a href="https://github.com/kbaley">github.com/kbaley</a>
    </div>
  </section>
</BaseLayout>
