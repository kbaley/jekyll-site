---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { formatPostDate, getArchivePosts } from "../../../../lib/archive";

export function getStaticPaths() {
  return getArchivePosts().map((post) => ({
    params: { year: post.year, month: post.month, slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
---

<BaseLayout
  title={post.title}
  description={`Archived post by Kyle Baley from ${formatPostDate(post.date)}.`}
  canonicalPath={post.archivePath}
  ogType="article"
>
  <article class="container post-shell">
    <a href="/writing/archive/">Back to archive</a>
    <header>
      <h1>{post.title}</h1>
      <p class="post-meta">
        <time datetime={post.date.toISOString()}>{formatPostDate(post.date)}</time>
      </p>
    </header>
    <div class="post-content" set:html={post.html} />
  </article>
</BaseLayout>
